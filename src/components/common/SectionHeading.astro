---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  level?: "h1" | "h2";
}

const { eyebrow, title, description, level = "h2" } = Astro.props;
const Heading = level;
---

<header class="max-w-3xl">
  <p class="text-accent text-sm font-bold tracking-[0.16em] uppercase">{eyebrow}</p>
  <Heading class="text-ink mt-4 text-3xl font-bold tracking-[-0.03em] text-balance sm:text-4xl lg:text-5xl">
    {title}
  </Heading>
  {description && <p class="text-muted mt-5 text-lg leading-8">{description}</p>}
</header>
