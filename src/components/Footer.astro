---
import { site } from "../data/site";
import type { Locale } from "../data/types";
import { getContent } from "../i18n/content";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getContent(locale);
const currentYear = new Date().getFullYear();
---

<footer class="border-line/70 border-t">
  <div class="page-container flex flex-col gap-5 py-8 text-sm sm:flex-row sm:items-center sm:justify-between">
    <nav class="flex items-center gap-3" aria-label={copy.footer.navigationLabel}>
      <a class="social-icon-link" href={site.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`LinkedIn — ${copy.common.opensNewTab}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V8.98h3.42v1.57h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.29ZM5.32 7.41a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.1 20.45H3.54V8.98H7.1v11.47Z" /></svg>
      </a>
      <a class="social-icon-link" href={site.github} target="_blank" rel="noopener noreferrer" aria-label={`GitHub — ${copy.common.opensNewTab}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.88c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.64-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.82c.85 0 1.71.12 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" /></svg>
      </a>
      <a class="social-icon-link" href={site.instagram} target="_blank" rel="noopener noreferrer" aria-label={`Instagram — ${copy.common.opensNewTab}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
        </svg>
      </a>
    </nav>
    <p class="text-muted">{copy.footer.developedBy} {site.name} · {currentYear}</p>
  </div>
</footer>
