---
import { Image } from "astro:assets";
import { site } from "../data/site";
import profilePhoto from "../assets/joao-jorge-profile.jpg";
---

<section class="page-container grid min-h-[calc(100svh-4.5rem)] items-center gap-14 py-20 lg:grid-cols-[minmax(0,1.25fr)_minmax(18rem,0.75fr)] lg:py-28">
  <div class="max-w-3xl">
    <p class="text-accent mb-5 text-base font-semibold tracking-wide sm:text-lg">
      {site.introduction}
    </p>

    <h1 class="text-ink text-5xl font-bold tracking-[-0.04em] sm:text-6xl lg:text-7xl">
      {site.role}
    </h1>

    <p class="text-muted mt-7 max-w-2xl text-lg leading-8 sm:text-xl sm:leading-9">
      {site.description}
    </p>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <a
        class="bg-accent text-canvas hover:bg-accent-strong inline-flex min-h-12 items-center justify-center rounded-lg px-6 py-3 text-sm font-bold transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        href="/#projetos"
      >
        Ver projetos
      </a>
      <a
        class="border-line bg-surface/60 text-ink hover:border-accent/60 hover:bg-elevated inline-flex min-h-12 items-center justify-center rounded-lg border px-6 py-3 text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        href={site.cv}
        download={site.cvDownloadName}
        aria-label="Descarregar o CV de João Jorge em PDF"
      >
        Descarregar CV
      </a>
    </div>

    <div class="mt-9 flex items-center gap-5" aria-label="Perfis profissionais">
      <a
        class="text-muted hover:text-accent rounded-sm text-sm font-semibold underline decoration-line underline-offset-4 transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        href={site.github}
        target="_blank"
        rel="noreferrer"
        aria-label="GitHub de João Jorge (abre num novo separador)"
      >
        GitHub
      </a>
      <span class="h-1 w-1 rounded-full bg-line" aria-hidden="true"></span>
      <a
        class="text-muted hover:text-accent rounded-sm text-sm font-semibold underline decoration-line underline-offset-4 transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
        href={site.linkedin}
        target="_blank"
        rel="noreferrer"
        aria-label="LinkedIn de João Jorge (abre num novo separador)"
      >
        LinkedIn
      </a>
    </div>
  </div>

  <div class="mx-auto w-full max-w-md lg:justify-self-end">
    <div class="relative aspect-[4/5] overflow-hidden rounded-3xl border border-line bg-surface shadow-2xl shadow-black/25">
      <Image
        class="h-full w-full object-cover object-[center_38%]"
        src={profilePhoto}
        alt="João Jorge num espaço interior junto a uma escadaria"
        width={720}
        quality={85}
        loading="eager"
        fetchpriority="high"
      />
      <div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-white/10 ring-inset"></div>
    </div>
  </div>
</section>
