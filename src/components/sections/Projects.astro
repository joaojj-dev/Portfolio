---
import type { Locale, SiteContent } from "../../data/types";
import { projects } from "../../data/projects";
import SectionHeading from "../common/SectionHeading.astro";
import ProjectCard from "../projects/ProjectCard.astro";

interface Props {
  locale: Locale;
  section: SiteContent["projectsSection"];
}

const { locale, section } = Astro.props;
const professional = projects.filter((project) => project.category === "professional");
const other = projects.filter((project) => project.category !== "professional");
---

<section class="section-block">
  <div id="projetos" class="page-container section-anchor">
    <SectionHeading eyebrow={section.eyebrow} title={section.title} />
    <div class="mt-12 grid gap-14">
      <div>
        <h3 class="text-ink text-xl font-bold sm:text-2xl">{section.professionalGroup}</h3>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {professional.map((project) => <ProjectCard {project} {locale} copy={section} />)}
        </div>
      </div>
      <div>
        <h3 class="text-ink text-xl font-bold sm:text-2xl">{section.otherGroup}</h3>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {other.map((project) => <ProjectCard {project} {locale} copy={section} />)}
        </div>
      </div>
    </div>
  </div>
</section>
