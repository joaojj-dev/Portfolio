---
import type { SiteContent } from "../../data/types";
import SectionHeading from "../common/SectionHeading.astro";

interface Props {
  content: SiteContent["about"];
}

const { content } = Astro.props;
---

<section id="sobre" class="section-block scroll-mt-28">
  <div class="page-container">
    <div class="max-w-4xl">
      <SectionHeading eyebrow={content.eyebrow} title={content.title} />
      <div class="text-muted mt-8 grid gap-5 text-lg leading-8">
        {content.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </div>
</section>
