---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/common/ButtonLink.astro";
import { getContent } from "../../i18n/content";

const locale = "en" as const;
const copy = getContent(locale);
---

<BaseLayout title={`${copy.common.notFoundTitle} | João Jorge`} description={copy.common.notFoundDescription} {locale} canonicalPath="/en/404/" alternatePath="/404.html" noIndex>
  <section class="page-container flex min-h-[65svh] items-center py-20">
    <div class="max-w-2xl">
      <p class="text-accent text-sm font-bold tracking-[0.16em] uppercase">Error 404</p>
      <h1 class="text-ink mt-4 text-4xl font-bold tracking-[-0.04em] sm:text-6xl">{copy.common.notFoundTitle}</h1>
      <p class="text-muted mt-6 text-lg leading-8">{copy.common.notFoundDescription}</p>
      <div class="mt-9"><ButtonLink href="/en/" label={copy.common.backHome} /></div>
    </div>
  </section>
</BaseLayout>
