---
import "../styles/global.css";
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Portfólio pessoal de João Jorge"
    />
    <title>João Jorge | Portfólio</title>
  </head>

  <body class="min-h-screen bg-slate-950 text-white">
    <main class="mx-auto flex min-h-screen max-w-6xl items-center px-6">
      <section>
        <p class="mb-3 text-lg font-medium text-blue-400">
          Olá, sou o
        </p>

        <h1 class="text-5xl font-bold tracking-tight sm:text-7xl">
          João Jorge
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          Este é o início do meu portfólio pessoal, desenvolvido com
          Astro, TypeScript e Tailwind CSS.
        </p>
      </section>
    </main>
  </body>
</html>
